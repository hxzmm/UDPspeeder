[Unit]
Description=UDPspeeder Service
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=-/root/udpspeeder/udpspeeder.conf
ExecStart=/root/udpspeeder/speederv2 $SPEEDER_OPTS
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
